{
  "name": "xiaowu-portal",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "A personal portal by Xiaowu (also known as Kirito). Building things with restraint.",
  "author": "Xiaowu",
  "license": "CC-BY-NC-4.0",
  "homepage": "https://xiaowulang.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaowulang-turbo/Xiaowu.github.io"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && biome check",
    "check:fix": "biome check --write",
    "typecheck": "astro check",
    "lint": "biome lint",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@iconify-json/lucide": "^1.2.109",
    "@tailwindcss/vite": "^4.0.0",
    "astro-icon": "^1.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
