---
/**
 * BaseLayout.astro — 全站基础布局
 *
 * 职责：
 * 1. 注入主题防闪 inline 脚本（在 paint 之前设置 data-theme）
 * 2. SEO meta（title / description / OG / canonical）
 * 3. 引入全局样式（tokens.css + globals.css）
 * 4. 渲染 SiteNav 与 SiteFooter
 *
 * 不包含：业务区块（由具体页面组装）
 */
import "@styles/tokens.css";
import "@styles/globals.css";

import SiteNav from "@components/ui/SiteNav.astro";
import SiteFooter from "@components/ui/SiteFooter.astro";
import { SITE } from "@data/site";
import { t } from "@i18n/index";

interface Props {
  /** 页面标题（最终显示为 "<title> · Xiaowu"，首页传 undefined） */
  title?: string;
  /** 页面描述（覆盖 SITE.description） */
  description?: string;
  /** 是否禁止搜索引擎索引 */
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;

const finalTitle = title ? `${title} · ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const finalDescription = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <meta name="author" content={SITE.author} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />

    <!--
      主题防闪：必须在 paint 之前同步执行。
      读取 localStorage["theme"]：
        - light / dark → 立即设置 <html data-theme> 并锁定 color-scheme 为对应值
        - system / 缺省 / 异常 → 不设置 data-theme（CSS 的 prefers-color-scheme 接管），
          但仍按系统偏好显式锁定 color-scheme，确保 MPA 切页之间的「过渡空白帧」
          浏览器使用与终态一致的底色，避免黑/白闪烁。

      同时为 <html> 添加 .js class —— 渐进增强标记：
      仅在 JS 可用时启用 reveal 动画等增强行为；
      JS 失败时所有内容保持完全可见（无障碍）。
    -->
    <script is:inline>
      (() => {
        const root = document.documentElement;
        let resolved = "light";
        try {
          const stored = localStorage.getItem("theme");
          if (stored === "light" || stored === "dark") {
            root.setAttribute("data-theme", stored);
            resolved = stored;
          } else {
            resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          }
        } catch (_) {
          /* localStorage 不可用时退化为系统偏好 */
          try {
            resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          } catch (__) {
            /* matchMedia 也不可用时保持 light 兜底 */
          }
        }
        // 锁定浏览器原生底色，覆盖 MPA 导航的过渡空白帧
        root.style.colorScheme = resolved;
        root.classList.add("js");
      })();
    </script>
  </head>

  <body>
    <a href="#main" class="skip-link">{t("common.skipToContent")}</a>

    <SiteNav pathname={Astro.url.pathname.replace(/\/$/, "") || "/"} />

    <main id="main">
      <slot />
    </main>

    <SiteFooter />

    <script>
      import { initReveal } from "@lib/reveal";

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initReveal);
      } else {
        initReveal();
      }
    </script>
  </body>
</html>
