---
/**
 * SiteNav.astro — 顶部主导航
 *
 * - 桌面：水平菜单
 * - 移动：水平菜单（v0.5 不做汉堡，靠克制版式横向放下；v1.0 实现汉堡）
 * - 当前路由用 1px 下边线高亮（不引入装饰色块）
 */
import { NAV } from "@data/nav";
import { SITE } from "@data/site";
import { t } from "@i18n/index";
import ThemeToggle from "@components/ui/ThemeToggle.astro";

interface Props {
  /** 当前页面路径（不含尾斜杠） */
  pathname: string;
}

const { pathname } = Astro.props;

const isActive = (href: string): boolean => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={SITE.name}>
      <span class="brand-mark">X</span>
      <span class="brand-name">{SITE.name}</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["nav-link", { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {t(item.labelKey)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-snug);
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1;
  }

  .brand-name {
    font-size: 1rem;
  }

  .primary-nav {
    flex: 1 1 auto;
    display: flex;
    justify-content: center;
  }

  .primary-nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    position: relative;
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-small);
    border-radius: var(--radius);
    transition:
      color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease);
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-bg-muted);
  }

  .nav-link.active {
    color: var(--color-text);
  }

  /* 激活态下划线：绝对定位，不占文档流，保证所有 tab 等高 */
  .nav-link.active::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -2px;
    width: 16px;
    height: 1px;
    background-color: var(--color-accent);
    transform: translateX(-50%);
    transform-origin: center;
    animation: nav-underline var(--dur-normal) var(--ease) both;
  }

  @keyframes nav-underline {
    from {
      transform: translateX(-50%) scaleX(0);
      opacity: 0;
    }
    to {
      transform: translateX(-50%) scaleX(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link.active::after {
      animation: none;
    }
  }

  .nav-actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* 移动端缩减 */
  @media (max-width: 640px) {
    .brand-name {
      display: none;
    }
    .nav-link {
      padding: var(--space-2);
    }
  }
</style>
