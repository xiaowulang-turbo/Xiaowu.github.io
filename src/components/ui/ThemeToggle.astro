---
/**
 * ThemeToggle.astro
 *
 * 三态循环切换器：system → light → dark → system
 * 数据-状态：通过 [data-theme-state] 暴露给 CSS 控制图标显示
 */
import Icon from "@components/primitives/Icon.astro";
import { t } from "@i18n/index";
---

<button
  type="button"
  class="theme-toggle"
  aria-label={t("theme.toggle")}
  data-theme-state="system"
>
  <Icon name="monitor" size={18} class="icon-system" />
  <Icon name="sun" size={18} class="icon-sun" />
  <Icon name="moon" size={18} class="icon-moon" />
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease),
      background-color var(--dur-fast) var(--ease);
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background-color: var(--color-bg-muted);
  }

  /*
   * 注意：下面的图标显隐规则必须用 :global()。
   * 原因：<Icon> 是包装组件（ThemeToggle → Icon.astro → astro-icon → <svg>），
   * Astro 的 scoped CSS 只能穿一层组件边界，到不了最终的 <svg>。
   * 这里把 :global() 严格限定在 .theme-toggle 后代下，作用域不会外溢。
   */
  .theme-toggle :global(.icon) {
    display: none;
  }

  .theme-toggle[data-theme-state="system"] :global(.icon-system) {
    display: block;
  }
  .theme-toggle[data-theme-state="light"] :global(.icon-sun) {
    display: block;
  }
  .theme-toggle[data-theme-state="dark"] :global(.icon-moon) {
    display: block;
  }
</style>

<script>
  import { applyTheme, getStoredTheme, setTheme, watchSystemTheme } from "@lib/theme";
  import type { Theme } from "@lib/theme";

  const ORDER: readonly Theme[] = ["system", "light", "dark"] as const;

  function syncButtonState(button: HTMLButtonElement, theme: Theme): void {
    button.setAttribute("data-theme-state", theme);
  }

  function init(): void {
    const buttons =
      document.querySelectorAll<HTMLButtonElement>(".theme-toggle");
    if (buttons.length === 0) return;

    const current = getStoredTheme();
    // 兜底纠正：inline script 在 head 里跑得最早，理论上 data-theme / color-scheme
    // 已经是终态。但若 localStorage 异常 / 浏览器扩展拦截过 inline，这里再同步一次。
    applyTheme(current);
    for (const btn of buttons) syncButtonState(btn, current);

    for (const btn of buttons) {
      btn.addEventListener("click", () => {
        const now = getStoredTheme();
        const idx = ORDER.indexOf(now);
        const next = ORDER[(idx + 1) % ORDER.length] ?? "system";
        setTheme(next);
        for (const b of buttons) syncButtonState(b, next);
      });
    }

    watchSystemTheme();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
