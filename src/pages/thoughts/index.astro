---
/**
 * /thoughts — 心得列表页（信条墙 · v1.0，RFC-0006）
 *
 * 薄装配层（ARCHITECTURE.md §4.2）：取数 → 下发 section。
 * 内容为按主题分组的短信条，数据源 src/data/thoughts.ts。
 * 现有 thoughts MDX collection 保留待长文，本页不使用。
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import ThoughtsPrinciples from "@components/sections/ThoughtsPrinciples.astro";
import { THOUGHTS } from "@data/thoughts";
import { t } from "@i18n/index";

const { groups } = THOUGHTS;
const isEmpty = groups.length === 0;
---

<BaseLayout title={t("page.thoughts.title")} description={t("page.thoughts.intro")}>
  <section class="page-head">
    <div class="container page-head-inner">
      <h1 class="title">{t("page.thoughts.title")}</h1>
      <p class="intro">{t("page.thoughts.intro")}</p>
    </div>
  </section>

  {!isEmpty && <ThoughtsPrinciples groups={groups} />}

  {
    isEmpty && (
      <section class="empty">
        <div class="container">
          <p class="empty-text">{t("thoughts.empty")}</p>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .page-head {
    padding-block: var(--space-24) var(--space-8);
  }

  .page-head-inner {
    max-width: var(--prose-max);
  }

  .title {
    margin: 0 0 var(--space-6);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: var(--leading-relaxed);
  }

  .empty {
    padding-block: var(--space-16) var(--space-24);
  }

  .empty-text {
    margin: 0;
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }
</style>
